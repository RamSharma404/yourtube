PORT=5000
DB_URL=mongodb+srv://<username>:<password>@cluster.mongodb.net/yourtube?retryWrites=true&w=majority

# Use real Razorpay test credentials for checkout. If placeholders are left in
# development, the backend returns a local mock payment order.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx

# Email OTP and invoice delivery.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=no-reply@yourtube.local

# Optional SMS OTP delivery webhook.
SMS_WEBHOOK_URL=
SMS_API_KEY=
